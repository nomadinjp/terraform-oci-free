---
# Copy this file to secrets.yml and fill in your actual values
# DO NOT commit secrets.yml to git

# OCI Credentials (from your terraform.tfvars)
oci_user: "ocid1.user.oc1..."
oci_fingerprint: "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
oci_tenancy: "ocid1.tenancy.oc1..."
oci_region: "ap-tokyo-1"
oci_namespace: "your-namespace-here"

# Paths to keys on the TARGET server (need to exist before running playbook)
oci_key_path: "/root/.oci/oci.pem"
ssh_key_path: "/root/.ssh/oci_free.pub"

# Instance configuration
instance_ocpus: 1
instance_memory: 6
instance_boot_volume_size: 50

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
# Get your chat_id from @userinfobot on Telegram
telegram_bot_token: "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
telegram_chat_id: "123456789"
