#!/bin/bash
# OCI Free Tier Auto-Renewal Script
# Deployed by Ansible

set -euo pipefail

# Configuration
WORK_DIR="{{ work_dir }}"
LOCK_FILE="${WORK_DIR}/lock/terraform.lock"
LOG_DIR="${WORK_DIR}/logs"
SUCCESS_FLAG="${WORK_DIR}/lock/.instance_created"
DOCKER_IMAGE="{{ docker_image }}"

# Telegram settings
TELEGRAM_BOT_TOKEN="{{ telegram_bot_token }}"
TELEGRAM_CHAT_ID="{{ telegram_chat_id }}"

# OCI Configuration for provider authentication
export OCI_USER="{{ oci_user }}"
export OCI_FINGERPRINT="{{ oci_fingerprint }}"
export OCI_TENANCY="{{ oci_tenancy }}"
export OCI_REGION="{{ oci_region }}"
export OCI_NAMESPACE="{{ oci_namespace }}"

# Functions
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_DIR}/terraform.log"
}

send_telegram() {
    local message="$1"
    if [[ -n "${TELEGRAM_BOT_TOKEN}" && -n "${TELEGRAM_CHAT_ID}" ]]; then
        curl -s -X POST \
            "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d "chat_id=${TELEGRAM_CHAT_ID}" \
            -d "text=${message}" \
            -d "parse_mode=HTML" >/dev/null 2>&1 || true
    fi
}

acquire_lock() {
    mkdir -p "$(dirname "$LOCK_FILE")"

    # Try to create lock file with exclusive access
    if ! ln -s /dev/null "$LOCK_FILE" 2>/dev/null; then
        # Check if the lock is stale (older than 30 minutes)
        if [[ -f "$LOCK_FILE" ]]; then
            lock_age=$(($(date +%s) - $(stat -c %Y "$LOCK_FILE" 2>/dev/null || stat -f %m "$LOCK_FILE")))
            if [[ $lock_age -gt 1800 ]]; then
                log "Removing stale lock file (age: ${lock_age}s)"
                rm -f "$LOCK_FILE"
                ln -s /dev/null "$LOCK_FILE" 2>/dev/null || {
                    log "Failed to acquire lock after removing stale lock"
                    exit 1
                }
            else
                log "Lock file exists and is active (age: ${lock_age}s), skipping"
                exit 0
            fi
        else
            log "Failed to acquire lock"
            exit 1
        fi
    fi

    # Remove lock on exit
    trap 'rm -f "$LOCK_FILE"' EXIT
}

run_terraform() {
    cd "${WORK_DIR}/terraform"

    # Run terraform init only if .terraform directory doesn't exist
    if [[ ! -d "${WORK_DIR}/terraform/.terraform" ]]; then
        log "Running terraform init..."
        docker run --rm \
            -v "${WORK_DIR}/terraform:/workspace:Z" \
            -v "{{ oci_key_path }}:/root/.oci/oci.pem:ro,Z" \
            -v "{{ ssh_key_path }}:/root/.ssh/oci_free.pub:ro,Z" \
            -e OCI_USER="${OCI_USER}" \
            -e OCI_FINGERPRINT="${OCI_FINGERPRINT}" \
            -e OCI_TENANCY="${OCI_TENANCY}" \
            -e OCI_REGION="${OCI_REGION}" \
            -e OCI_NAMESPACE="${OCI_NAMESPACE}" \
            --workdir /workspace \
            "${DOCKER_IMAGE}" \
            init -backend-config=state.config >> "${LOG_DIR}/terraform.log" 2>&1
    fi

    # Run terraform apply and capture output
    log "Running terraform apply..."
    local output
    output=$(docker run --rm \
        -v "${WORK_DIR}/terraform:/workspace:Z" \
        -v "{{ oci_key_path }}:/root/.oci/oci.pem:ro,Z" \
        -v "{{ ssh_key_path }}:/root/.ssh/oci_free.pub:ro,Z" \
        -e OCI_USER="${OCI_USER}" \
        -e OCI_FINGERPRINT="${OCI_FINGERPRINT}" \
        -e OCI_TENANCY="${OCI_TENANCY}" \
        -e OCI_REGION="${OCI_REGION}" \
        -e OCI_NAMESPACE="${OCI_NAMESPACE}" \
        --workdir /workspace \
        "${DOCKER_IMAGE}" \
        apply -auto-approve 2>&1)

    local exit_code=$?

    echo "$output" >> "${LOG_DIR}/terraform.log"

    # Check for successful apply with actual changes
    if [[ $exit_code -eq 0 ]]; then
        # Check if output contains "Apply complete!" and no "No changes" message
        if echo "$output" | grep -q "Apply complete!" && ! echo "$output" | grep -q "No changes." ; then
            return 0  # Success with changes
        else
            return 1  # Success but no changes
        fi
    else
        return 2  # Failure
    fi
}

main() {
    acquire_lock

    # Check if instance was already created successfully
    if [[ -f "$SUCCESS_FLAG" ]]; then
        log "Instance already created (flag file exists). Skipping. Run 'reset.yml' to start over."
        exit 0
    fi

    log "Starting Terraform run..."

    if run_terraform; then
        log "Terraform apply completed with changes - creating success flag"
        touch "$SUCCESS_FLAG"

        send_telegram "<b>OCI Free Tier Instance Created</b>

Region: {{ oci_region }}
Shape: VM.Standard.A1.Flex
Time: $(date '+%Y-%m-%d %H:%M:%S JST')

<b>Cron will now skip runs.</b> To restart, run: ansible-playbook reset.yml"
    else
        log "Terraform completed with no changes or failed"
    fi
}

main
